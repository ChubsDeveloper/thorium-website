############################################################
# Thorium WoW — Environment Configuration (TEMPLATE)
############################################################
# IMPORTANT: This file is a TEMPLATE ONLY
# DO NOT COMMIT YOUR .env FILE - it contains secrets!
# Copy this to .env and fill in your actual values

# ==============================================
# 🌐 DOMAIN & HOSTING
# ==============================================
BASE_URL=https://your-domain.org
VOTE_CALLBACK_URL=https://your-domain.org/api/vote-callback.php
SITE_BASE_URL=https://your-domain.org
SESSION_NAME=THORIUMSESSID
SESSION_DOMAIN=.your-domain.org
SESSION_SECURE=true
SESSION_SAMESITE=Lax


########################
# 🗄️ DATABASE CONFIGURATION
########################
# Main Website Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=thorium_website
DB_USER=your_db_username
DB_PASS=your_db_password_here

# Character Database
CHAR_DB_HOST=127.0.0.1
CHAR_DB_PORT=3306
CHAR_DB_NAME=characters
CHAR_DB_USER=your_db_username
CHAR_DB_PASS=your_db_password_here

# Authentication Database
AUTH_DB_HOST=127.0.0.1
AUTH_DB_PORT=3306
AUTH_DB_NAME=auth
AUTH_DB_USER=your_db_username
AUTH_DB_PASS=your_db_password_here

# Database Options / Diagnostics
DB_PERSISTENT=true
DB_PROFILER=false
DB_PROFILER_TABLE=false
DB_PROFILER_LOG=/var/log/thorium/query.log
DB_PROFILER_SAMPLE=1
DB_PROFILER_STACK=false
DB_AUTO_DDL=0


########################
# 🎮 GAME SERVER SETTINGS
########################
REALMLIST=your.realm.ip
EXPANSION=3.3.5a


########################
# 🌫️ FOG EFFECT SETTINGS
########################
FOG_PRESET=emerald_mist
FOG_OPACITY=0.05
FOG_ENABLED=true

# Available presets:
# emerald_mist - Soft green-blue fog (default theme)
# ocean_depths - Deep blue underwater feel
# mystic_forest - Purple-green magical forest
# arctic_winds - Cool white-blue icy fog
# shadow_realm - Dark purple-black mysterious
# sunset_glow - Warm orange-pink evening colors
# disabled - No fog effect


########################
# ✨ PARTICLE EFFECTS SETTINGS
########################
PARTICLES_ENABLED=false
PARTICLES_TYPE=fireflies
PARTICLES_DENSITY=medium
PARTICLES_SPEED=slow
PARTICLES_COLOR=auto

# Available types:
# leaves - Natural autumn leaves with realistic physics and veins
# petals - Soft flower petals with gentle movement and gradients
# fireflies - Glowing magical fireflies with organic life-like motion
# sparkles - Crystalline magical sparkles with natural variations
# snow - Detailed snowflakes with realistic air drift patterns
# disabled - No particles

# Density options: low (12), medium (25), high (40), very_high (60)
# Speed options: very_slow, slow, medium, fast, very_fast
# Color options: auto (natural colors per type), green, blue, gold, purple, white, rainbow

# Movement & Physics Options
PARTICLES_DIRECTION=down
PARTICLES_SWIRL=false
PARTICLES_ROTATION=true
PARTICLES_WIND=0.8
PARTICLES_GRAVITY=0.3

# Available directions: down, up, left, right, diagonal_left, diagonal_right, swirl
# Wind strength: 0.0 (no wind) to 2.0 (strong wind effect)
# Gravity: 0.5 (light fall) to 2.0 (heavy fall)
# Swirl: true/false - adds natural spiral movement patterns
# Rotation: true/false - particles tumble and rotate naturally as they move


########################
# 🔐 SECURITY SECRETS
########################
# IMPORTANT: Generate new keys using: openssl rand -hex 32
# Change these to unique values for your installation
APP_KEY=your_app_key_here_64_hex_characters
HASH_SALT=your_hash_salt_here_64_hex_characters
JWT_SECRET=your_jwt_secret_here_64_hex_characters
DOWNLOAD_SECRET=your_download_secret_here_64_hex_characters
PRELAUNCH_ACCESS_KEY=your_prelaunch_key_here_64_hex_characters


########################
# 🎨 THEME & UI SETTINGS
########################
DEFAULT_THEME=thorium-emeraldforest
THEME_LOCK=false


########################
# 🛡️ SECURITY CONFIGURATION
########################
# Session & Authentication
SESSION_LIFETIME=7200
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=3
LOGIN_LOCKOUT_TIME=1800

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=3600

# TLS & Browser Security
FORCE_HTTPS=true
SECURE_COOKIES=true
CSRF_PROTECTION=true
XSS_PROTECTION=true

# Security Logging
SECURITY_LOG_ENABLED=true
SECURITY_LOG_LEVEL=warning
LOG_FAILED_LOGINS=true

# Two-Factor Authentication
TWO_FACTOR_ENABLED=false
TWO_FACTOR_ISSUER=Thorium WoW


########################
# 🔧 DEVELOPMENT & DEBUGGING
########################
DEBUG=false
CACHE_ENABLED=true
DEBUG_GATE=false
VOTE_DEBUG_ENABLED=false


########################
# 💰 PAYPAL INTEGRATION
########################
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_SANDBOX=false
PAYPAL_CURRENCY=USD
PAYPAL_WEBHOOK_ID=your_webhook_id_here
PAYPAL_ME_HANDLE=YourPayPalHandle
PAYPAL_RECEIVER_EMAIL=your-email@example.com


########################
# 💎 DONATION SYSTEM
########################
DONATION_MIN_AMOUNT=1.00
DONATION_MAX_AMOUNT=500.00
DONATION_POINTS_PER_DOLLAR=100


########################
# 📁 FILE DOWNLOADS
########################
DOWNLOAD_TTL=3600


########################
# 💬 DISCORD INTEGRATION
########################
DISCORD_INVITE=https://discord.gg/your-invite-code
DISCORD_GUILD_ID=your_guild_id
DISCORD_THEME=dark
DISCORD_SHOW_WIDGET=true


########################
# 🚧 PRELAUNCH GATE
########################
PRELAUNCH_MODE=false
PRELAUNCH_ALLOWED_ROLES=admin,staff,tester
PRELAUNCH_COOKIE_NAME=TWOw_BETA
PRELAUNCH_EXPIRES_DAYS=14
HOMEPAGE_DEV_BANNER=true
HOMEPAGE_DEV_HEADLINE="Server in active development"
HOMEPAGE_DEV_TEXT="Register today to reserve your name and get notified when we go live. Pre-register rewards await at launch."
HOMEPAGE_DEV_PERKS="Launch rewards, News & patch notes"


########################
# 🗳️ VOTING SYSTEM
########################
VOTE_AUTO_CONFIRM_HOURS=2
WEEKEND_VOTE_MULTIPLIER=2.0
GTOP_PINGBACK_KEY=your_gtop_pingback_key_here


########################
# 🗺️ REALM VISIBILITY & RBAC
########################
# Realm visibility (players see only DEFAULT_REALM_ID; other realms can be staff-only)
REALMS_ADMIN_ONLY_IDS=2
DEFAULT_REALM_ID=1

# RBAC threshold for Admin UI (191 = GM+, 195 = Admin+)
ADMIN_MIN_PERMISSION_ID=191


############################################################
# 📧 MAIL CONFIGURATION
############################################################
MAIL_DRIVER=smtp
MAIL_HOST=your-smtp-host.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_ENCRYPTION=tls
MAIL_FROM=support@your-domain.org
MAIL_FROM_NAME="Your Project Name"
MAIL_LOGO_PATH=/path/to/your/logo.png
MAIL_LOGO_URL=https://your-domain.org/assets/logo.png
